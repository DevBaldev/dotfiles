#!/bin/bash

set -e # Exit immediately if a command exits with a non-zero status

sys_update() {
  sudo pacman -Syu --noconfirm
}

paru_install() {
  if ! command -v paru &>/dev/null; then
    sudo pacman -Sy rust --noconfirm
    git clone https://aur.archlinux.org/paru.git
    (cd paru && makepkg -si --noconfirm)
    rm -rf paru
  fi
}

install_pkgs() {
  sudo pacman -Sy --needed "$@" --noconfirm
}

change_shell() {
  install_pkgs fish starship
  chsh -s "$(which fish)"
}

link_dotfiles() {
  source_dir="$(pwd)/configs"
  for file in "$source_dir"/*; do
    target="$HOME/.config/$(basename "$file")"
    if [ ! -e "$target" ]; then
      ln -sf "$file" "$target"
    else
      echo "Warning: $target already exists. Skipping link creation."
    fi
  done
}

pkgs_install() {
  install_pkgs mesa vulkan-dzn                                                                # Drivers
  install_pkgs noto-fonts-{cjk,emoji,extra} ttf-{cascadia-code,jetbrains-mono}-nerd              # Fonts
  install_pkgs rust lsd bat zoxide ripgrep tealdeer img2pdf starship                                      # tools
  install_pkgs pyright python-uv ruff                                                            # Python
  install_pkgs {lua,bash}-language-server vscode-{css,html}-languageserver                       # LSP
  install_pkgs stylua shfmt tombi clang rust-analyzer prettier                                   # Formaters
  install_pkgs yazi ffmpeg 7zip jq poppler fd fzf imagemagick btop                               # Yazi
}

app_setup() {
  tldr -u
}

main() {
  sys_update
  #paru_install
  #change_shell
  link_dotfiles
  pkgs_install
  app_setup
}

main
